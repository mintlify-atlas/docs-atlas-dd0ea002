  "keyFeatures": [
    "FHIR R4-compliant Clinical Data Repository (CDR)",
    "End-to-end auth with OAuth, OpenID, and SMART-on-FHIR",
    "Serverless Bots for custom automation logic",
    "React UI component library for healthcare apps",
    "On-premise Agent for HL7/MLLP, ASTM, and DICOM connectivity",
    "FHIRcast support for real-time context synchronization",
    "GraphQL API for flexible data querying",
    "Self-hostable on AWS, Azure, GCP, or Docker",
    "HIPAA, SOC2, ONC, and multi-compliance framework support",
    "Medplum CLI for project and deployment management"
  ],
  "publicApiSurface": [
    "MedplumClient (core SDK)",
    "MedplumProvider (React context provider)",
    "@medplum/core: readResource, createResource, updateResource, deleteResource, searchResources",
    "@medplum/core: executeBot, createAttachment, uploadMedia",
    "@medplum/react: ResourceForm, ResourceTable, SearchControl, SignInForm",
    "@medplum/react-hooks: useMedplum, useMedplumContext, useSubscription",
    "@medplum/cli: medplum login, medplum get, medplum post, medplum put, medplum delete",
    "@medplum/cli: medplum bot create, medplum bot deploy",
    "FHIR REST API: GET/POST/PUT/DELETE /fhir/R4/{resourceType}",
    "FHIR Search API: GET /fhir/R4/{resourceType}?{searchParams}",
    "GraphQL API: POST /fhir/R4/$graphql",
    "OAuth2 endpoints: /oauth2/authorize, /oauth2/token, /oauth2/userinfo",
    "SMART App Launch support",
    "Subscription webhooks and WebSocket subscriptions"
  ]
}
